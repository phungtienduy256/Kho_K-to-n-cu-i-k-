<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="12dp">

    <TextView android:text="MÃ BẢNG LƯƠNG" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etMaBL" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="VD: BL001"
        android:layout_marginBottom="6dp"/>

    <!-- FIX: Đổi định dạng tháng sang MM/yy cho khớp với Phiếu Kho -->
    <TextView android:text="THÁNG" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etThang" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="VD: 04/2026"
        android:inputType="text"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="Nhân Viên" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <Spinner android:id="@+id/spinnerMaNV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>
    <TextView android:id="@+id/tvNVEmpty"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Chưa có nhân viên nào. Vui lòng thêm NHAN_VIEN trước."
        android:textColor="#C00000" android:visibility="gone"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="MÃ NV KẾ TOÁN" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etMaNVKT" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="VD: KT001"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="LƯƠNG CƠ BẢN" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etLuongCoBan" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="0" android:inputType="numberDecimal"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="TỔNG PHỤ CẤP" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etPhuCap" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="0" android:inputType="numberDecimal"
        android:layout_marginBottom="6dp"/>

    <TextView android:text="TỔNG KHẤU TRỪ" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <EditText android:id="@+id/etKhauTru" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="0" android:inputType="numberDecimal"
        android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/tvTongLuong"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Tổng lương: 0 đ" android:textSize="16sp"
        android:textStyle="bold" android:textColor="#375623"
        android:background="#E2EFDA" android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnThanhToan"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="THANH TOÁN" android:backgroundTint="#375623"
        android:layout_marginBottom="8dp"/>

    <ListView android:id="@+id/lvBangLuong"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>