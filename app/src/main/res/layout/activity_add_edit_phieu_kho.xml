<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:text="Mã Phiếu" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <EditText android:id="@+id/etMaPhieu"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="VD: PK001" android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:text="Loại Phiếu" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <Spinner android:id="@+id/spinnerLoaiPhieu"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView android:text="Ngày Lập (yyyy-MM-dd)" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <EditText android:id="@+id/etNgayLap"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="2026-04-14" android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:text="Mã NV Kho" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <EditText android:id="@+id/etMaNVKho"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="VD: NV001" android:layout_marginBottom="12dp"/>

        <TextView android:text="Nhà Cung Cấp (NCC)" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <Spinner android:id="@+id/spinnerMaNCC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/tvNCCEmpty"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chưa có NCC nào. Vui lòng thêm NCC trước."
            android:textColor="#C00000" android:visibility="gone"
            android:layout_marginBottom="12dp"/>


        <TextView android:text="Trạng Thái Thanh Toán" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textStyle="bold"/>
        <Spinner android:id="@+id/spinnerTrangThai"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btnLuu"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="LƯU" android:backgroundTint="#2E75B6"/>
    </LinearLayout>
</ScrollView>

